# EditorConfig is awesome: https://EditorConfig.org

root = true

############################
# Global defaults
############################

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

############################
# PHP
############################

[*.php]
indent_style = space
indent_size = 4

############################
# JavaScript / TypeScript
############################

[*.{js,jsx,ts,tsx}]
indent_style = space
indent_size = 2

############################
# CSS / SCSS
############################

[*.{css,scss,sass,less}]
indent_style = space
indent_size = 2

############################
# JSON / YAML
############################

[*.json]
indent_style = space
indent_size = 2

[*.yml]
indent_style = space
indent_size = 2

############################
# Markdown
############################

[*.md]
trim_trailing_whitespace = false
insert_final_newline = true