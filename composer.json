{
    "name": "callismart/smart-license-server",
    "description": "A PHP, database-agnostic application for privately hosting, licensing, updating, and distributing custom software, WordPress plugins, and themes.",
    "license": "MIT",
    "authors": [
        {
            "name": "Callistus Nwachukwu",
            "email": "admin@callismart.com.ng"
        }
    ],
    "require": {
        "php": "^8.4",
        "league/commonmark": "^2.7",
        "callismart/http": "^1.0",
        "callismart/dto": "^1.0",
        "callismart/dbprism": "^0.1.36"
    },
    "suggest": {
        "ext-pdo_mysql": "Required for MySQL 8.0.45 support.",
        "ext-pdo_pgsql": "Required for PostgreSQL support.",
        "ext-sqlite3": "Required for SQLite support (v3.35+ for expanded ALTER TABLE)."
    },
    "require-dev": {
        "php-stubs/wp-cli-stubs": "^2.12",
        "phpunit/phpunit": "^12"
    },
    "autoload": {
        "psr-4": {
            "SmartLicenseServer\\": "src/"
        }
    }
}