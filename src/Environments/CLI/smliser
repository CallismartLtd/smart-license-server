<?php
/**
 * Smart License Server CLI bootstrap file.
 *
 * Entry point for running Smart License Server in a command-line
 * environment. Boots the CLI environment adapter, loads the core
 * command registry, and delegates dispatch to CLIRunner.
 *
 * Usage:
 *   smliser [command]
 *   smliser help
 *
 * @author  Callistus Nwachukwu
 * @package SmartLicenseServer\Environments\CLI
 * @since   0.2.0
 */

// Guard — must be run from CLI only.
if ( 'cli' !== PHP_SAPI ) {
    function_exists( 'http_response_code' ) && http_response_code( 403 );
    exit( 'This script can only be run from the command line.' );
}

use SmartLicenseServer\Environments\CLI\SetUp;

/**
 * The absolute path to the Smart License Server root directory. Adjust as needed.
 * 
 * @example '/usr/local/www/smart-license-server'
 * @var string
 */
$app_root   = '/var/www/html/apiv1.callismart.local';

/**
 * Absolute path to the Smart License Server source code directory. Adjust as needed.
 * 
 * @example '/usr/local/www/smart-license-server/src/'
 * @var string
 */
$src_path   = $app_root . '/wp-content/plugins/smart-license-server/';

// Core constants.
/**
 * Absolute path to the Smart License Server application root.
 *
 * Represents the base directory of the hosting environment when running
 * outside WordPress (CLI mode).
 *
 * @var string
 */
define( 'SMLISER_ABSPATH',  $app_root . '/' );

/**
 * Absolute path to the Smart License Server installation directory.
 *
 * Points to the plugin/app root where core files and resources reside.
 *
 * @var string
 */
define( 'SMLISER_PATH', $src_path );

/**
 * Absolute path to the CLI bootstrap file.
 *
 * Used for runtime reference and execution context identification.
 *
 * @var string
 */
define( 'SMLISER_FILE', __FILE__ );

/**
 * Absolute path to the Smart License Server source directory.
 *
 * Used for autoloading and resolving internal class files.
 *
 * @var string
 */
define( 'SMLISER_SRC_DIR', SMLISER_PATH . 'src/' );

/**
 * Current application version.
 *
 * Used for version tracking, compatibility checks, and CLI output.
 *
 * @var string
 */
define( 'SMLISER_VER', '0.2.0' );

/**
 * Current database schema version.
 *
 * Used to determine whether database migrations or updates are required.
 *
 * @var string
 */
define( 'SMLISER_DB_VER', '0.2.0' );

/**
 * Base URL for the application.
 *
 * Not applicable in CLI context, therefore defined as an empty string.
 *
 * @var string
 */
define( 'SMLISER_URL', '' );

/**
 * Human-readable application name.
 *
 * Used in CLI output, logs, and system identification.
 *
 * @var string
 */
define( 'SMLISER_APP_NAME', 'Smart License Server' );

// Register the autoloader.
require_once SMLISER_SRC_DIR . 'Autoloader.php';
SetUp::instance();